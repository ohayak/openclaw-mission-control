  "functions": [
    {
      "name": "initDatabase",
      "description": "Initialize better-sqlite3 database connection with WAL mode. Creates database file if it does not exist. Sets PRAGMA journal_mode=WAL and foreign_keys=ON.",
      "inputs": [
        {
          "name": "dbPath",
          "type_ref": "str",
          "required": true,
          "default": "",
          "description": "Path to SQLite database file (or :memory: for in-memory)",
          "validators": []
        }
      ],
      "output_type": "Database",
      "error_cases": [
        {
          "name": "DatabaseOpenError",
          "condition": "Cannot open or create database file at dbPath",
          "error_type": "DatabaseError",
          "error_data": {}
        },
        {
          "name": "PragmaSetError",
          "condition": "Cannot set WAL mode or foreign_keys pragma",
          "error_type": "DatabaseError",
          "error_data": {}
        }
      ],
      "preconditions": [
        "dbPath is a valid filesystem path or ':memory:'"
      ],
      "postconditions": [
        "Database connection is open",
        "WAL mode is enabled",
        "Foreign keys are enabled"
      ],
      "idempotent": false,
      "side_effects": [],
      "structured_side_effects": [
        {
          "kind": "writes_file",
          "target": "dbPath",
          "description": "Creates SQLite database file if it does not exist"
        },
        {
          "kind": "mutates_state",
          "target": "global database connection",
          "description": "Opens persistent database connection handle"
        }
      ],
      "performance_budget": {
        "p95_latency_ms": 100,
        "max_memory_mb": 50,
        "complexity": null
      }
    },
    {
      "name": "runMigrations",
      "description": "Apply all pending migrations from lib/db/migrations/ directory. Uses BEGIN IMMEDIATE transaction to prevent concurrent execution. Migrations are numbered SQL files (001_initial.sql, 002_add_column.sql, etc.). Tracks applied migrations in internal 'migrations' table.",
      "inputs": [
        {
          "name": "db",
          "type_ref": "Database",
          "required": true,
          "default": "",
          "description": "Open database connection",
          "validators": []
        }
      ],
      "output_type": "Result",
      "error_cases": [
        {
          "name": "MigrationDirectoryNotFound",
          "condition": "lib/db/migrations/ directory does not exist",
          "error_type": "MigrationError",
          "error_data": {}
        },
        {
          "name": "MigrationFileMalformed",
          "condition": "Migration file contains invalid SQL",
          "error_type": "MigrationError",
          "error_data": {}
        },
        {
          "name": "ConcurrentMigrationAttempt",
          "condition": "Another process is running migrations (transaction lock conflict)",
          "error_type": "MigrationError",
          "error_data": {}
        },
        {
          "name": "DatabaseWriteError",
          "condition": "Cannot write to migrations table or execute migration SQL",
          "error_type": "DatabaseError",
          "error_data": {}
        }
      ],
      "preconditions": [
        "db.isOpen is true",
        "lib/db/migrations/ directory exists"
      ],
      "postconditions": [
        "All pending migrations are applied",
        "migrations table is updated",
        "Database version is current"
      ],
      "idempotent": false,
      "side_effects": [],
      "structured_side_effects": [
        {
          "kind": "reads_file",
          "target": "lib/db/migrations/*.sql",
          "description": "Reads migration SQL files from disk"
        },
        {
          "kind": "mutates_state",
          "target": "database schema",
          "description": "Executes DDL/DML statements to modify database schema"
        },
        {
          "kind": "mutates_state",
          "target": "migrations table",
          "description": "Inserts records for applied migrations"
        }
      ],
      "performance_budget": {
        "p95_latency_ms": 500,
        "max_memory_mb": 20,
        "complexity": "O(n)"
      }
    },
    {
      "name": "closeDatabase",
      "description": "Close database connection and release resources. Safe to call multiple times (idempotent).",
      "inputs": [
